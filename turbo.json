{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": ["NODE_ENV", "WEB_URL", "NEXT_PUBLIC_WEB_URL"],
  "tasks": {
    "start": {},
    "build": {
      "dependsOn": ["^build"],
      "env": ["NODE_ENV", "WEB_URL"]
    },
    "dev": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["^deploy"]
    },
    "serve": {},
    "lint": {}
  }
}
