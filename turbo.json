{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "AUDIT_ENCRYPTION_CURRENT_VERSION",
    "DATABASE_URL",
    "MFA_ENCRYPTION_KEY_V1",
    "NEXT_PUBLIC_WEB_URL",
    "NODE_ENV",
    "WEB_URL"
  ],
  "globalPassThroughEnv": [
    "AUDIT_ENCRYPTION_KEY_V*",
    "CI",
    "CONFIRM_DATABASE_BASELINE",
    "E2E_DATABASE_URL",
    "E2E_SUPERADMIN_CONTACT_EMAIL",
    "E2E_SUPERADMIN_LOGIN_NAME",
    "E2E_SUPERADMIN_PASSWORD",
    "PERSONS_PERFORMANCE_DATABASE_URL"
  ],
  "tasks": {
    "@repo/database#build": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "dependsOn": ["build"],
      "persistent": true
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
