generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id                     String    @id @default(cuid())
  loginName              String    @unique
  contactEmail           String?
  contactEmailVerifiedAt DateTime?
  passwordHash           String
  firstName              String
  lastName               String
  role                   UserRole  @default(USER)
  permissions            Json?
  isActive               Boolean   @default(true)
  isProtected            Boolean   @default(false)
  mustChangePassword     Boolean   @default(false)
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  lastLoginAt            DateTime?
  passwordChangedAt      DateTime?
  securityVersion        Int       @default(0)
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  sessions              Session[]
  auditLogs             AuditLog[]             @relation("AuditActor")
  targetedAuditLogs     AuditLog[]             @relation("AuditTarget")
  archivedStaffProfile  ArchivedStaffProfile?
  loginNameReservations LoginNameReservation[]

  @@index([contactEmail])
  @@index([role])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([deletedAt, isActive])
  @@index([deletedAt, lastLoginAt])
  @@index([deletedAt, lockedUntil])
  @@index([deletedAt, mustChangePassword])
  @@index([deletedAt, role])
  @@index([loginName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_loginName_trgm_idx")
  @@index([contactEmail(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_contactEmail_trgm_idx")
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_firstName_trgm_idx")
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_lastName_trgm_idx")
}

/// Permanent ownership history for authentication identifiers. A login name
/// remains attached to its original user even when that user changes names or
/// is soft-deleted, so it can never be reassigned to another identity.
model LoginNameReservation {
  loginName String   @id
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
}

model Session {
  id              String   @id @default(cuid())
  userId          String
  securityVersion Int      @default(0)
  token           String   @unique
  expiresAt       DateTime
  idleExpiresAt   DateTime @default(dbgenerated("(CURRENT_TIMESTAMP + '00:30:00'::interval)"))
  lastSeenAt      DateTime @default(now())
  rememberMe      Boolean  @default(false)
  userAgent       String?
  ipAddress       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([userId, idleExpiresAt])
  @@index([userId, createdAt])
  @@index([token])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  ACCOUNT_LOCKED
  SESSION_INVALIDATE
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  USER_ACTIVATE
  USER_DEACTIVATE
  PERMISSION_UPDATE
}

enum AuditCategory {
  AUTH
  USER
  PERMISSION
  SYSTEM
}

model AuditLog {
  id           String        @id @default(cuid())
  userId       String?
  user         User?         @relation("AuditActor", fields: [userId], references: [id], onDelete: SetNull)
  targetUserId String?
  targetUser   User?         @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  action       AuditAction
  category     AuditCategory
  description  String
  metadata     Json?
  poleKey      String?
  pageKey      String?
  tabKey       String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime      @default(now())

  @@index([userId])
  @@index([userId, action])
  @@index([userId, createdAt])
  @@index([userId, createdAt, id])
  @@index([targetUserId])
  @@index([targetUserId, createdAt])
  @@index([targetUserId, createdAt, id])
  @@index([poleKey, createdAt, id])
  @@index([poleKey, pageKey, createdAt, id])
  @@index([pageKey, createdAt, id])
  @@index([action])
  @@index([action, createdAt, id])
  @@index([category])
  @@index([category, createdAt, id])
  @@index([createdAt])
  @@index([createdAt, id])
}

/// Read-only archive of the legacy StaffProfile table.
/// The application no longer writes these fields, but keeping the historical
/// values prevents the migration baseline from destroying existing data.
model ArchivedStaffProfile {
  id           String    @id
  userId       String?   @unique
  displayName  String?
  jobTitle     String?
  department   String?
  discordId    String?
  phone        String?
  timezone     String?
  joinedAt     DateTime?
  internalNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([department])
  @@index([discordId])
  @@index([jobTitle])
  @@index([joinedAt])
}

model RateLimit {
  id           String    @id @default(cuid())
  key          String    @unique
  count        Int       @default(0)
  firstAttempt DateTime  @default(now())
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([key])
  @@index([blockedUntil])
}
