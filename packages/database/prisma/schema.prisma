generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum MfaChallengePurpose {
  LOGIN
  SETUP
}

enum MfaAuthenticationMethod {
  TOTP
  RECOVERY_CODE
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum PersonStructureStatus {
  IN_STRUCTURE
  OUTSIDE_STRUCTURE
}

enum PartnerOrganizationCategoryType {
  SPONSOR
  PARTNER
}

enum PartnerOrganizationStatus {
  PROSPECT
  DISCUSSION
  ACTIVE
  ENDED
  CLOSED
}

enum PartnerContactChannelType {
  EMAIL
  PHONE
}

enum AuditFieldChangeType {
  CREATE
  UPDATE
  DELETE
}

enum AuditValueStorageMode {
  PLAIN
  ENCRYPTED
  NONE
}

model User {
  id                     String    @id @default(cuid())
  loginName              String    @unique
  contactEmail           String?
  contactEmailVerifiedAt DateTime?
  passwordHash           String
  firstName              String
  lastName               String
  role                   UserRole  @default(USER)
  permissions            Json?
  isActive               Boolean   @default(true)
  /// Singleton application root. Database constraints require this account
  /// to remain active, undeleted and administrative.
  isProtected            Boolean   @default(false)
  mustChangePassword     Boolean   @default(false)
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  lastLoginAt            DateTime?
  passwordChangedAt      DateTime?
  mfaEnabledAt           DateTime?
  securityVersion        Int       @default(0)
  /// Irreversible deletion marker. Deleted rows are anonymous, immutable
  /// technical tombstones retained only for audit and identifier ownership.
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  sessions                    Session[]
  auditLogs                   AuditLog[]              @relation("AuditActor")
  targetedAuditLogs           AuditLog[]              @relation("AuditTarget")
  archivedStaffProfile        ArchivedStaffProfile?
  loginNameReservations       LoginNameReservation[]
  totpCredential              TotpCredential?
  totpEnrollment              TotpEnrollment?
  mfaRecoveryCodes            MfaRecoveryCode[]
  mfaLoginChallenge           MfaLoginChallenge?
  createdNotifications        Notification[]          @relation("NotificationCreator")
  notificationRecipients      NotificationRecipient[]
  updatedSystemSettings       SystemSetting[]         @relation("SystemSettingUpdater")
  createdPartnerOrganizations PartnerOrganization[]   @relation("PartnerOrganizationCreator")
  updatedPartnerOrganizations PartnerOrganization[]   @relation("PartnerOrganizationUpdater")
  updatedPartnerSituations    PartnerOrganization[]   @relation("PartnerOrganizationSituationUpdater")
  createdPartnerFollowUps     PartnerFollowUpEntry[]  @relation("PartnerFollowUpAuthor")
  completedPartnerActions     PartnerFollowUpAction[] @relation("PartnerFollowUpActionCompleter")

  @@index([contactEmail])
  @@index([role])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([deletedAt, isActive])
  @@index([deletedAt, lastLoginAt])
  @@index([deletedAt, lockedUntil])
  @@index([deletedAt, mustChangePassword])
  @@index([deletedAt, role])
  @@index([mfaEnabledAt])
  @@index([loginName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_loginName_trgm_idx")
  @@index([contactEmail(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_contactEmail_trgm_idx")
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_firstName_trgm_idx")
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_lastName_trgm_idx")
}

/// Permanent ownership history for authentication identifiers. A login name
/// remains attached to its original user even when that user changes names or
/// is irreversibly deleted, so it can never be reassigned to another identity.
model LoginNameReservation {
  loginName String   @id
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
}

model Session {
  id                        String                  @id @default(cuid())
  userId                    String
  securityVersion           Int                     @default(0)
  token                     String                  @unique
  expiresAt                 DateTime
  idleExpiresAt             DateTime                @default(dbgenerated("(CURRENT_TIMESTAMP + '00:30:00'::interval)"))
  lastSeenAt                DateTime                @default(now())
  rememberMe                Boolean                 @default(false)
  passwordReauthenticatedAt DateTime?
  criticalMfaVerifiedAt     DateTime?
  mfaVerifiedAt             DateTime
  mfaMethod                 MfaAuthenticationMethod
  userAgent                 String?
  ipAddress                 String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([userId, idleExpiresAt])
  @@index([userId, createdAt])
  @@index([token])
}

/// Encrypted active TOTP seed. Secrets never live on the User row so ordinary
/// user reads cannot accidentally expose authentication material.
model TotpCredential {
  userId           String    @id
  secretCiphertext String
  secretIv         String
  secretAuthTag    String
  secretKeyVersion Int       @default(1)
  lastUsedTimeStep BigInt?
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastUsedAt])
}

/// Short-lived replacement seed. Keeping enrollment separate means an active
/// authenticator continues working until the new one is successfully proven.
model TotpEnrollment {
  userId           String   @id
  secretCiphertext String
  secretIv         String
  secretAuthTag    String
  secretKeyVersion Int      @default(1)
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

/// Recovery codes are high-entropy, single-use values. Only salted hashes are
/// stored; plaintext codes are returned once when generated.
model MfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  salt      String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId, usedAt])
}

/// Password-first login state. The browser receives only a random HttpOnly
/// token whose hash is stored here; no application session exists yet.
model MfaLoginChallenge {
  id                  String              @id @default(cuid())
  userId              String              @unique
  tokenHash           String              @unique
  purpose             MfaChallengePurpose
  securityVersion     Int
  credentialUpdatedAt DateTime?
  rememberMe          Boolean             @default(false)
  attempts            Int                 @default(0)
  expiresAt           DateTime
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([purpose, expiresAt])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  ACCOUNT_LOCKED
  SESSION_INVALIDATE
  MFA_ENABLED
  MFA_DISABLED
  MFA_RECOVERY_CODE_USED
  MFA_RECOVERY_CODES_REGENERATED
  MFA_RESET
  STEP_UP_SUCCESS
  STEP_UP_FAILED
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  USER_ACTIVATE
  USER_DEACTIVATE
  PERMISSION_UPDATE
  AUDIT_EXPORT
  NOTIFICATION_SEND
  SYSTEM_SETTING_UPDATE
  BACKGROUND_JOB_UPDATE
  PERSON_CREATE
  PERSON_UPDATE
  PERSON_DELETE
  PARTNER_CREATE
  PARTNER_UPDATE
  PARTNER_STATUS_UPDATE
  PARTNER_PERIOD_CREATE
  PARTNER_PERIOD_UPDATE
  PARTNER_CONTACTS_UPDATE
  PARTNER_FOLLOW_UP_CREATE
  PARTNER_FOLLOW_UP_UPDATE
  PARTNER_FOLLOW_UP_DELETE
  PARTNER_FOLLOW_UP_COMPLETE
  PARTNER_MERGE
  PARTNER_DELETE
}

enum AuditCategory {
  AUTH
  USER
  PERMISSION
  SYSTEM
  PERSON
  PARTNER
}

enum AuditEventKind {
  ACTIVITY
  CONNECTION
}

enum AuditStream {
  AUTHENTICATION
  SECURITY
  IDENTITY
  AUTHORIZATION
  SYSTEM
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  NEUTRAL
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id                        String         @id @default(cuid())
  userId                    String?
  user                      User?          @relation("AuditActor", fields: [userId], references: [id], onDelete: Restrict)
  actorDisplayNameSnapshot  String?
  actorLoginNameSnapshot    String?
  actorRoleSnapshot         UserRole?
  targetUserId              String?
  targetUser                User?          @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  targetDisplayNameSnapshot String?
  targetLoginNameSnapshot   String?
  targetRoleSnapshot        UserRole?
  action                    AuditAction
  category                  AuditCategory
  eventKind                 AuditEventKind @default(ACTIVITY)
  stream                    AuditStream    @default(SYSTEM)
  outcome                   AuditOutcome   @default(SUCCESS)
  severity                  AuditSeverity  @default(INFO)
  eventVersion              Int            @default(1)
  description               String
  metadata                  Json?
  poleKey                   String?
  pageKey                   String?
  tabKey                    String?
  entityType                String?        @db.VarChar(40)
  entityId                  String?        @db.VarChar(128)
  requestId                 String?
  ipAddress                 String?
  userAgent                 String?
  createdAt                 DateTime       @default(now())

  fieldChanges AuditFieldChange[]

  @@unique([id, entityType, entityId])
  @@index([userId, action])
  @@index([userId, createdAt, id])
  @@index([targetUserId, action])
  @@index([targetUserId, createdAt, id])
  @@index([poleKey, createdAt, id])
  @@index([poleKey, pageKey, createdAt, id])
  @@index([pageKey, createdAt, id])
  @@index([eventKind, createdAt, id])
  @@index([stream, createdAt, id])
  @@index([outcome, createdAt, id])
  @@index([severity, createdAt, id])
  @@index([requestId])
  @@index([action, createdAt, id])
  @@index([category, createdAt, id])
  @@index([entityType, entityId, createdAt, id])
  @@index([createdAt, id])
  @@index([actorDisplayNameSnapshot(ops: raw("gin_trgm_ops"))], type: Gin, map: "AuditLog_actorDisplayNameSnapshot_trgm_idx")
  @@index([actorLoginNameSnapshot(ops: raw("gin_trgm_ops"))], type: Gin, map: "AuditLog_actorLoginNameSnapshot_trgm_idx")
  @@index([targetDisplayNameSnapshot(ops: raw("gin_trgm_ops"))], type: Gin, map: "AuditLog_targetDisplayNameSnapshot_trgm_idx")
  @@index([targetLoginNameSnapshot(ops: raw("gin_trgm_ops"))], type: Gin, map: "AuditLog_targetLoginNameSnapshot_trgm_idx")
}

model AuditEncryptionKeyVersion {
  version     Int      @id
  algorithm   String   @default("AES-256-GCM") @db.VarChar(32)
  firstUsedAt DateTime @default(now())

  fieldChanges AuditFieldChange[]
}

model AuditFieldChange {
  id               String                @id @default(cuid())
  auditLogId       String
  entityType       String                @db.VarChar(40)
  entityId         String                @db.VarChar(128)
  sectionKey       String                @db.VarChar(64)
  fieldKey         String                @db.VarChar(100)
  recordId         String?               @db.VarChar(128)
  changeType       AuditFieldChangeType
  valueMode        AuditValueStorageMode
  beforeValue      String?               @db.VarChar(512)
  afterValue       String?               @db.VarChar(512)
  valuesCiphertext Bytes?
  valuesIv         Bytes?
  valuesAuthTag    Bytes?
  valueKeyVersion  Int?
  beforeHash       String?               @db.Char(64)
  afterHash        String?               @db.Char(64)
  createdAt        DateTime

  auditLog             AuditLog                   @relation(fields: [auditLogId, entityType, entityId], references: [id, entityType, entityId], onDelete: Cascade)
  encryptionKeyVersion AuditEncryptionKeyVersion? @relation(fields: [valueKeyVersion], references: [version], onDelete: Restrict)

  @@index([auditLogId])
  @@index([entityType, entityId, sectionKey, fieldKey, recordId, createdAt, id], map: "AuditFieldChange_history_lookup_idx")
  @@index([valueKeyVersion])
}

model Person {
  id                  String                @id @default(cuid())
  nickname            String?               @db.VarChar(80)
  normalizedNickname  String?               @db.VarChar(160)
  firstName           String?               @db.VarChar(100)
  normalizedFirstName String?               @db.VarChar(200)
  lastName            String?               @db.VarChar(100)
  normalizedLastName  String?               @db.VarChar(200)
  sortName            String                @db.VarChar(401)
  birthDate           DateTime?             @db.Date
  structureStatus     PersonStructureStatus @default(OUTSIDE_STRUCTURE)
  version             Int                   @default(1)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  emails          PersonEmail[]
  phones          PersonPhone[]
  socialProfiles  PersonSocialProfile[]
  partnerContacts PartnerContact[]

  @@index([createdAt, id])
  @@index([structureStatus, createdAt, id])
  @@index([updatedAt, id])
  @@index([structureStatus, updatedAt, id])
  @@index([sortName, id])
  @@index([structureStatus, sortName, id])
  @@index([normalizedNickname(ops: raw("gin_trgm_ops"))], type: Gin, map: "Person_normalizedNickname_trgm_idx")
  @@index([normalizedFirstName(ops: raw("gin_trgm_ops"))], type: Gin, map: "Person_normalizedFirstName_trgm_idx")
  @@index([normalizedLastName(ops: raw("gin_trgm_ops"))], type: Gin, map: "Person_normalizedLastName_trgm_idx")
  @@index([normalizedNickname(ops: raw("varchar_pattern_ops"))], map: "Person_normalizedNickname_prefix_idx")
  @@index([normalizedFirstName(ops: raw("varchar_pattern_ops"))], map: "Person_normalizedFirstName_prefix_idx")
  @@index([normalizedLastName(ops: raw("varchar_pattern_ops"))], map: "Person_normalizedLastName_prefix_idx")
}

model PersonEmail {
  id              String   @id @default(cuid())
  personId        String
  email           String   @db.VarChar(320)
  normalizedEmail String   @db.VarChar(320)
  label           String   @db.VarChar(40)
  isPrimary       Boolean  @default(false)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, normalizedEmail])
  @@index([normalizedEmail])
  @@index([normalizedEmail(ops: raw("varchar_pattern_ops"))], map: "PersonEmail_normalizedEmail_prefix_idx")
}

model PersonPhone {
  id              String   @id @default(cuid())
  personId        String
  phone           String   @db.VarChar(40)
  normalizedPhone String   @db.VarChar(16)
  label           String   @db.VarChar(40)
  isPrimary       Boolean  @default(false)
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, normalizedPhone])
  @@index([normalizedPhone])
  @@index([normalizedPhone(ops: raw("varchar_pattern_ops"))], map: "PersonPhone_normalizedPhone_prefix_idx")
}

model PersonSocialProfile {
  id                       String   @id @default(cuid())
  personId                 String
  networkKey               String   @db.VarChar(40)
  identifier               String?  @db.VarChar(100)
  normalizedIdentifier     String?  @db.VarChar(100)
  profileUrl               String?  @db.VarChar(2048)
  normalizedProfileUrl     String?  @db.VarChar(2048)
  normalizedProfileUrlHash String?  @db.Char(64)
  label                    String   @db.VarChar(40)
  isPrimary                Boolean  @default(false)
  version                  Int      @default(1)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, networkKey, normalizedIdentifier], map: "PersonSocialProfile_person_network_identifier_key")
  @@unique([personId, networkKey, normalizedProfileUrlHash], map: "PersonSocialProfile_person_network_url_hash_key")
  @@index([normalizedIdentifier])
  @@index([normalizedIdentifier(ops: raw("varchar_pattern_ops"))], map: "PersonSocialProfile_normalizedIdentifier_prefix_idx")
  @@index([normalizedProfileUrlHash])
}

model PersonDeletionTombstone {
  personId            String   @id @db.VarChar(128)
  deletionOperationId String   @unique @db.VarChar(191)
  deletedAt           DateTime @default(now())
}

model PartnerOrganization {
  id                   String                    @id @default(cuid())
  name                 String                    @db.VarChar(200)
  normalizedName       String                    @db.VarChar(400)
  description          String?                   @db.VarChar(500)
  status               PartnerOrganizationStatus @default(PROSPECT)
  website              String?                   @db.VarChar(2048)
  normalizedDomain     String?                   @db.VarChar(253)
  currentSituation     String?                   @db.VarChar(1000)
  situationUpdatedAt   DateTime?
  situationUpdatedById String?
  createdById          String?
  updatedById          String?
  version              Int                       @default(1)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  situationUpdatedBy User?                               @relation("PartnerOrganizationSituationUpdater", fields: [situationUpdatedById], references: [id], onDelete: SetNull)
  createdBy          User?                               @relation("PartnerOrganizationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?                               @relation("PartnerOrganizationUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  categories         PartnerOrganizationCategory[]
  channels           PartnerOrganizationContactChannel[]
  periods            PartnerRelationshipPeriod[]
  contacts           PartnerContact[]
  followUps          PartnerFollowUpEntry[]
  mergeRedirects     PartnerOrganizationMergeRedirect[]  @relation("PartnerOrganizationMergeTarget")

  @@index([normalizedName, id])
  @@index([status, normalizedName, id])
  @@index([updatedAt, id])
  @@index([status, updatedAt, id])
  @@index([normalizedDomain])
  @@index([normalizedName(ops: raw("gin_trgm_ops"))], type: Gin, map: "PartnerOrganization_normalizedName_trgm_idx")
}

model PartnerOrganizationCategory {
  id             String                          @id @default(cuid())
  organizationId String
  category       PartnerOrganizationCategoryType
  createdAt      DateTime                        @default(now())

  organization PartnerOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, category])
  @@index([category, organizationId])
}

model PartnerOrganizationContactChannel {
  id              String                    @id @default(cuid())
  organizationId  String
  type            PartnerContactChannelType
  value           String                    @db.VarChar(320)
  normalizedValue String                    @db.VarChar(320)
  label           String                    @db.VarChar(40)
  isPrimary       Boolean                   @default(false)
  version         Int                       @default(1)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  organization PartnerOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type, normalizedValue])
  @@index([normalizedValue])
  @@index([organizationId, type, createdAt])
}

model PartnerRelationshipPeriod {
  id             String    @id @default(cuid())
  organizationId String
  startedOn      DateTime? @db.Date
  endedOn        DateTime? @db.Date
  closedAt       DateTime?
  closingNote    String?   @db.VarChar(300)
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization PartnerOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, closedAt])
  @@index([startedOn])
  @@index([endedOn])
}

model PartnerContact {
  id             String    @id @default(cuid())
  organizationId String
  personId       String?
  label          String    @db.VarChar(80)
  isPrimary      Boolean   @default(false)
  startedOn      DateTime? @db.Date
  endedOn        DateTime? @db.Date
  closedAt       DateTime?
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization PartnerOrganization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  person       Person?                @relation(fields: [personId], references: [id], onDelete: SetNull)
  followUps    PartnerFollowUpEntry[]

  @@index([organizationId, closedAt, createdAt])
  @@index([personId, closedAt])
}

model PartnerFollowUpEntry {
  id               String   @id @default(cuid())
  organizationId   String
  partnerContactId String?
  text             String   @db.VarChar(4000)
  occurredAt       DateTime
  authorId         String?
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization   PartnerOrganization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  partnerContact PartnerContact?        @relation(fields: [partnerContactId], references: [id], onDelete: SetNull)
  author         User?                  @relation("PartnerFollowUpAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  action         PartnerFollowUpAction?

  @@index([organizationId, occurredAt, id])
  @@index([partnerContactId])
  @@index([authorId])
}

model PartnerFollowUpAction {
  id            String    @id @default(cuid())
  entryId       String    @unique
  description   String    @db.VarChar(300)
  dueOn         DateTime? @db.Date
  completedAt   DateTime?
  completedById String?
  version       Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entry       PartnerFollowUpEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  completedBy User?                @relation("PartnerFollowUpActionCompleter", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([completedAt, dueOn, id])
  @@index([completedById])
}

model PartnerOrganizationDeletionTombstone {
  organizationId      String   @id @db.VarChar(128)
  deletionOperationId String   @unique @db.VarChar(191)
  deletedAt           DateTime @default(now())
}

model PartnerOrganizationMergeRedirect {
  sourceOrganizationId String   @id @db.VarChar(128)
  targetOrganizationId String
  mergeOperationId     String   @unique @db.VarChar(191)
  mergedAt             DateTime @default(now())

  targetOrganization PartnerOrganization @relation("PartnerOrganizationMergeTarget", fields: [targetOrganizationId], references: [id], onDelete: Restrict)

  @@index([targetOrganizationId])
}

/// Read-only archive of the legacy StaffProfile table.
/// The application no longer writes these fields, but keeping the historical
/// values prevents the migration baseline from destroying existing data.
model ArchivedStaffProfile {
  id           String    @id
  userId       String?   @unique
  displayName  String?
  jobTitle     String?
  department   String?
  discordId    String?
  phone        String?
  timezone     String?
  joinedAt     DateTime?
  internalNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([department])
  @@index([discordId])
  @@index([jobTitle])
  @@index([joinedAt])
}

model RateLimit {
  id           String    @id @default(cuid())
  key          String    @unique
  count        Int       @default(0)
  firstAttempt DateTime  @default(now())
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([key])
  @@index([blockedUntil])
}

/// Durable in-application notification. Delivery is separated from the
/// per-user read state so one message can be fanned out without duplication.
model Notification {
  id          String               @id @default(cuid())
  type        String
  title       String
  body        String
  href        String?
  severity    NotificationSeverity @default(INFO)
  dedupeKey   String?              @unique
  createdById String?
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())

  createdBy  User?                   @relation("NotificationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  recipients NotificationRecipient[]

  @@index([createdAt, id])
  @@index([expiresAt])
  @@index([type, createdAt, id])
}

model NotificationRecipient {
  id             String    @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, archivedAt, createdAt, notificationId])
  @@index([userId, readAt, archivedAt])
}

/// Non-secret runtime configuration. Credentials and encryption material must
/// remain in the deployment secret manager and never be stored in this table.
model SystemSetting {
  key         String   @id
  value       Json
  description String?
  version     Int      @default(1)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("SystemSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt])
  @@index([updatedById])
}
