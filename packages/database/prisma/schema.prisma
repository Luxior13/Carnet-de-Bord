generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  firstName           String
  lastName            String
  role                UserRole  @default(USER)
  permissions         Json?
  isActive            Boolean   @default(true)
  isProtected         Boolean   @default(false)
  mustChangePassword  Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime?
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions             Session[]
  auditLogs            AuditLog[]            @relation("AuditActor")
  targetedAuditLogs    AuditLog[]            @relation("AuditTarget")
  archivedStaffProfile ArchivedStaffProfile?

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([deletedAt, isActive])
  @@index([deletedAt, lastLoginAt])
  @@index([deletedAt, lockedUntil])
  @@index([deletedAt, mustChangePassword])
  @@index([deletedAt, role])
  @@index([email(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_email_trgm_idx")
  @@index([firstName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_firstName_trgm_idx")
  @@index([lastName(ops: raw("gin_trgm_ops"))], type: Gin, map: "User_lastName_trgm_idx")
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  rememberMe Boolean  @default(false)
  userAgent  String?
  ipAddress  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([userId, createdAt])
  @@index([token])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  PASSWORD_CHANGE
  PASSWORD_RESET
  ACCOUNT_LOCKED
  SESSION_INVALIDATE
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  USER_ACTIVATE
  USER_DEACTIVATE
  PERMISSION_UPDATE
}

enum AuditCategory {
  AUTH
  USER
  PERMISSION
  SYSTEM
}

model AuditLog {
  id           String        @id @default(cuid())
  userId       String?
  user         User?         @relation("AuditActor", fields: [userId], references: [id], onDelete: SetNull)
  targetUserId String?
  targetUser   User?         @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  action       AuditAction
  category     AuditCategory
  description  String
  metadata     Json?
  poleKey      String?
  pageKey      String?
  tabKey       String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime      @default(now())

  @@index([userId])
  @@index([userId, action])
  @@index([userId, createdAt])
  @@index([userId, createdAt, id])
  @@index([targetUserId])
  @@index([targetUserId, createdAt])
  @@index([targetUserId, createdAt, id])
  @@index([poleKey, createdAt, id])
  @@index([poleKey, pageKey, createdAt, id])
  @@index([pageKey, createdAt, id])
  @@index([action])
  @@index([action, createdAt, id])
  @@index([category])
  @@index([category, createdAt, id])
  @@index([createdAt])
  @@index([createdAt, id])
}

/// Read-only archive of the legacy StaffProfile table.
/// The application no longer writes these fields, but keeping the historical
/// values prevents the migration baseline from destroying existing data.
model ArchivedStaffProfile {
  id           String    @id
  userId       String?   @unique
  displayName  String?
  jobTitle     String?
  department   String?
  discordId    String?
  phone        String?
  timezone     String?
  joinedAt     DateTime?
  internalNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([department])
  @@index([discordId])
  @@index([jobTitle])
  @@index([joinedAt])
}

model RateLimit {
  id           String    @id @default(cuid())
  key          String    @unique
  count        Int       @default(0)
  firstAttempt DateTime  @default(now())
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([key])
  @@index([blockedUntil])
}
