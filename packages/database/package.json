{
  "name": "@repo/database",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "prisma generate",
    "db:backup": "bun run scripts/backup-database.ts",
    "db:restore": "bun run scripts/restore-database.ts",
    "db:migrate:baseline": "bun run scripts/baseline-existing-database.ts",
    "db:migrate:deploy": "bun run scripts/safe-migrate-deploy.ts",
    "db:migrate:status": "prisma migrate status",
    "db:persons:performance-check": "bun run scripts/verify-persons-performance.ts",
    "db:permissions:retire-historical": "bun run scripts/retire-historical-permission-overrides.ts",
    "db:root:mfa:recover": "bun run scripts/reset-root-mfa.ts",
    "deploy": "bun run db:migrate:deploy",
    "seed": "bun run prisma/seed.ts",
    "lint": "eslint \"{src,scripts,test}/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"{src,scripts,test}/**/*.{js,jsx,ts,tsx}\" --fix",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test test/database-backup-format.test.ts test/database-backup-signature.test.ts test/persons-performance-plan.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-keys-custom-order": "^2.2.1",
    "eslint-plugin-turbo": "^2.10.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^2.4.3",
    "prisma": "6.19.3",
    "prisma-json-types-generator": "^5.1.1",
    "server-only": "^0.0.1"
  }
}
