# Base URL
WEB_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3001

# 32 random bytes encoded as Base64. Keep this key outside Git and back it up
# separately from the database; losing it makes active TOTP seeds unreadable.
# Generate one with: bun -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
MFA_ENCRYPTION_KEY_V1=REPLACE_WITH_32_RANDOM_BYTES_IN_BASE64

# Audit chiffré des données personnelles. Les anciennes clés doivent rester
# disponibles tant qu'une base ou une sauvegarde restaurable les référence.
AUDIT_ENCRYPTION_CURRENT_VERSION=1
AUDIT_ENCRYPTION_KEY_V1=REPLACE_WITH_32_RANDOM_BYTES_IN_BASE64

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/carnet

# End-to-end tests (a separate database is mandatory)
# The database or schema name must contain the isolated marker "e2e" or "test".
E2E_DATABASE_URL=postgresql://user:password@localhost:5432/carnet_e2e
E2E_SUPERADMIN_LOGIN_NAME=e2e-admin
E2E_SUPERADMIN_CONTACT_EMAIL=e2e-admin@carnet.local
E2E_SUPERADMIN_PASSWORD=ChangeThisE2EPassword1!

# Superadmin seed
# Required in production; bind the seed to one immutable owner identity.
SEED_SUPERADMIN_USER_ID=
SEED_SUPERADMIN_LOGIN_NAME=superadmin
# Optional contact address; it is not used to sign in and starts unverified.
SEED_SUPERADMIN_CONTACT_EMAIL=superadmin@carnet.local
SEED_SUPERADMIN_PASSWORD=ChangeThisPassword1!
