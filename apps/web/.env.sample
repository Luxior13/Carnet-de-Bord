E2E_DATABASE_URL=postgresql://user:password@localhost:5432/carnet_e2e
E2E_SUPERADMIN_EMAIL=e2e-admin@carnet.local
E2E_SUPERADMIN_PASSWORD=change-this-e2e-password

# Superadmin seed
SEED_SUPERADMIN_EMAIL=superadmin@carnet.local
SEED_SUPERADMIN_PASSWORD=change-this-password
