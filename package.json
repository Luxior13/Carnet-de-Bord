{
  "name": "carnet-pro",
  "private": true,
  "devDependencies": {
    "eslint": "^9.39.5",
    "npm-check-updates": "^18.3.1",
    "prettier": "^3.9.5",
    "turbo": "^2.10.4"
  },
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "turbo run build",
    "check": "bun run lint && bun run typecheck && bun run --filter web check:architecture && bun run test && bun run build && bun run --filter web check:performance",
    "dev": "turbo run dev",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@repo/database",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=web",
    "typecheck": "turbo run typecheck",
    "clear": "bun scripts/clear-workspace.mjs",
    "ncu": "ncu -ws -i"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "flatted": "3.4.2",
    "postcss": "8.5.18",
    "rollup": "4.62.2",
    "vite": "7.3.6"
  }
}
