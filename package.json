{
  "name": "carnet-pro",
  "devDependencies": {
    "eslint": "^9.32.0",
    "npm-check-updates": "^18.0.2",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5"
  },
  "packageManager": "bun@1.2.19",
  "scripts": {
    "build": "turbo run build --env-mode=loose",
    "dev": "turbo run dev",
    "deploy": "turbo run deploy --env-mode=loose",
    "start": "turbo run start --env-mode=loose",
    "lint": "turbo run lint",
    "clear": "find . -type d \\( -name 'node_modules' -o -name 'dist' -o -name '.next' -o -name '.turbo' -o -name '.prisma' -o -name 'generated' \\) -prune -print -exec rm -rf '{}' +",
    "ncu": "ncu -ws -i"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "swr": "^2.4.1"
  }
}
